{
  "id": "nodebb-plugin-cp-chat-harmony",
  "name": "CP Chat Harmony",
  "description": "Harmony mobile chat overlay with translation, voice, media compression, smart replies, Wukong bridge compatibility and multilingual UI.",
  "url": "https://github.com/Hurt6465-ai/nodebb-plugin-cp-chat",
  "library": "./library.js",
  "hooks": [
    {
      "hook": "static:app.load",
      "method": "init"
    },
    {
      "hook": "filter:admin.header.build",
      "method": "addAdminNavigation"
    }
  ],
  "scripts": [
    "public/src/client.js"
  ],
  "acpScripts": [
    "public/src/admin.js"
  ],
  "modules": {
    "../admin/plugins/cp-chat-harmony.js": "./public/src/admin.js"
  },
  "scss": [
    "scss/client.scss",
    "scss/admin.scss"
  ],
  "staticDirs": {
    "public": "public"
  },
  "templates": "templates",
  "languages": "languages",
  "defaultLang": "zh-CN"
}
